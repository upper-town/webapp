<div class="d-flex flex-wrap align-items-end justify-content-center gap-3 mb-4 pb-3 border-bottom border-body-secondary servers-index-filter">
  <div class="d-flex flex-column gap-1 servers-index-filter-game">
    <%= form.label(:game_ids, Server.human_attribute_name(:game_id), class: "form-label text-body-secondary mb-0") %>
    <%= render(GameMultiSelectFilterComponent.new(
      form: form,
      selected_ids: selected_value_game_ids,
      aria_label: Server.human_attribute_name(:game_id),
      request: request
    )) %>
  </div>
  <div class="d-flex flex-nowrap gap-3 align-items-end servers-index-filter-period-country">
    <div class="d-flex flex-column gap-1 flex-fill servers-index-filter-period-country__field servers-index-filter-period-country__period">
      <%= form.label(:period, ServerStat.human_attribute_name(:period), class: "form-label text-body-secondary mb-0") %>
      <%= render(PeriodSelectComponent.new(
        form,
        selected_value: selected_value_period,
        select_class: "form-select",
        data_action: "change->servers#filter"
      )) %>
    </div>
    <div class="d-flex flex-column gap-1 flex-fill servers-index-filter-period-country__field servers-index-filter-period-country__country">
      <%= form.label(:country_codes, Server.human_attribute_name(:country_code), class: "form-label text-body-secondary mb-0") %>
      <%= render(CountryMultiSelectFilterComponent.new(
        form: form,
        selected_ids: selected_value_country_codes,
        aria_label: Server.human_attribute_name(:country_code),
        request: request
      )) %>
    </div>
  </div>
</div>
