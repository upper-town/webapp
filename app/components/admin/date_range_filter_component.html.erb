<div class="admin-date-range-filter admin-multi-select-filter">
  <div class="dropdown">
    <button
      type="button"
      class="<%= DEFAULT_SELECT_CLASS %> dropdown-toggle d-flex align-items-center justify-content-between text-start"
      id="<%= dropdown_id %>"
      data-bs-toggle="dropdown"
      data-bs-auto-close="outside"
      aria-expanded="false"
      aria-haspopup="dialog"
      aria-label="<%= t("admin.shared.date_range_filter.aria_label") %>"
    >
      <span class="admin-multi-select-filter__trigger-text text-truncate">
        <%= trigger_text %>
      </span>
      <i class="bi bi-chevron-down admin-multi-select-filter__caret" aria-hidden="true"></i>
    </button>
    <div class="dropdown-menu p-2" role="dialog" aria-label="<%= t("admin.shared.date_range_filter.aria_label") %>">
      <div class="mb-2">
        <div class="mb-2">
          <div class="d-flex gap-2 align-items-end flex-wrap">
            <div class="flex-grow-1 min-w-0">
              <%= form.label(start_date_param, t("admin.shared.date_range_filter.start_date"), class: "form-label small mb-1") %>
              <%= form.date_field(start_date_param, value: format_date_for_input(start_date), class: "form-control form-control-sm") %>
            </div>
            <% if show_time %>
              <div class="flex-shrink-0">
                <%= form.label(start_time_param, t("admin.shared.date_range_filter.start_time"), class: "form-label small mb-1") %>
                <%= form.time_field(start_time_param, value: format_time_for_input(start_time), step: 1, class: "form-control form-control-sm") %>
              </div>
            <% end %>
          </div>
        </div>
        <div class="mb-2">
          <div class="d-flex gap-2 align-items-end flex-wrap">
            <div class="flex-grow-1 min-w-0">
              <%= form.label(end_date_param, t("admin.shared.date_range_filter.end_date"), class: "form-label small mb-1") %>
              <%= form.date_field(end_date_param, value: format_date_for_input(end_date), class: "form-control form-control-sm") %>
            </div>
            <% if show_time %>
              <div class="flex-shrink-0">
                <%= form.label(end_time_param, t("admin.shared.date_range_filter.end_time"), class: "form-label small mb-1") %>
                <%= form.time_field(end_time_param, value: format_time_for_input(end_time), step: 1, class: "form-control form-control-sm") %>
              </div>
            <% end %>
          </div>
        </div>
        <% if show_time_zone %>
          <div class="mb-2">
            <%= form.label(time_zone_param, t("admin.shared.date_range_filter.time_zone"), class: "form-label small mb-1") %>
            <%= form.select(time_zone_param, options_for_select(time_zone_options, time_zone), {}, class: "form-select form-select-sm") %>
          </div>
        <% end %>
        <% if show_date_column %>
          <div class="mb-2">
            <%= form.label(date_column_param, t("admin.users.index.filter.date_column"), class: "form-label small mb-1") %>
            <%= form.select(date_column_param, options_for_select(date_column_options, date_column), {}, class: "form-select form-select-sm") %>
          </div>
        <% end %>
      </div>
      <div class="input-group input-group-sm">
        <button
          type="submit"
          class="btn btn-outline-primary"
          aria-label="<%= t("admin.shared.filter_multiselect_apply") %>"
        >
          <%= t("admin.shared.filter_multiselect_apply") %>
        </button>
        <% if show_clear_button? %>
          <%= link_to(clear_url, class: "btn btn-outline-secondary d-flex align-items-center justify-content-center", aria: { label: clear_button_aria_label }) do %>
            <%= t("admin.shared.clear_search") %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
