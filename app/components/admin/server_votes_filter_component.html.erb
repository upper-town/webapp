<%= render(Admin::FilterComponent.new(
  form: form,
  params_to_remove: FILTER_PARAMS,
  request: request
)) do %>
  <%= render(Admin::DateRangeFilterComponent.new(
    form: form,
    start_date: start_date,
    end_date: end_date,
    time_zone: time_zone,
    time_zone_param_present: time_zone_param_present,
    show_time_zone: true,
    request: request
  )) %>
  <%= render(Admin::GameMultiSelectFilterComponent.new(
    form: form,
    selected_ids: selected_game_ids,
    options: game_options,
    aria_label: ServerVote.human_attribute_name(:game),
    request: request
  )) %>
  <%= render(Admin::ServerMultiSelectFilterComponent.new(
    form: form,
    selected_ids: selected_server_ids,
    options: server_options,
    aria_label: ServerVote.human_attribute_name(:server),
    request: request
  )) %>
  <%= render(Admin::AccountMultiSelectFilterComponent.new(
    form: form,
    selected_ids: selected_account_ids,
    selected_labels: selected_account_labels,
    aria_label: ServerVote.human_attribute_name(:account),
    request: request
  )) %>
<% end %>
